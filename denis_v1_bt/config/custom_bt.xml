<root main_tree_to_execute="MainTree" BTCPP_format="4">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="3" name="NavigateRecovery">
      <PipelineSequence name="MainPath">
        <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>

        <ReactiveFallback name="ZoneControllerSelector">
          <Sequence name="InOda">
            <CheckZone zone_name="oda"/>
            <FollowPath path="{path}" controller_id="OdaController"/>
          </Sequence>
          <Sequence name="InRampa">
            <CheckZone zone_name="ramp"/>
            <FollowPath path="{path}" controller_id="RampaController"/>
          </Sequence>
          <Sequence name="InAntre">
            <CheckZone zone_name="antre"/>
            <FollowPath path="{path}" controller_id="AntreController"/>
          </Sequence>
          <FollowPath path="{path}" controller_id="FollowPath"/>
        </ReactiveFallback>
      </PipelineSequence>

      <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
    </RecoveryNode>
  </BehaviorTree>
</root>